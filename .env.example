# Copy to .env and fill in real values. Do not commit .env (see .gitignore).

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=database
POSTGRES_URL=postgres://user:password@db:5432/database

CLIENT_ID=
CLIENT_SECRET=
# Local (Vite + proxy): use the Vite origin so cookies apply to :5173.
REDIRECT_URI=redirectUri
# After login, browser is sent to APP_PUBLIC_URL + /timeline
APP_PUBLIC_URL=http://localhost:5173

HMAC_SECRET_KEY=
JWT_SECRET=
ACCESS_TOKEN_DURATION=1000
REFRESH_TOKEN_DURATION=1000

# redis:6379 for docker-compose; Fly/Upstash: host:port
REDIS_ADDR=
# Optional if REDIS_ADDR is set; used when REDIS_ADDR is empty (e.g. REDIS_HOST=redis REDIS_PORT=6379)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Local HTTP: false or unset. Fly (HTTPS): true
COOKIE_SECURE=

# Leave empty for API-only local runs. Production image sets /app/web/dist
WEB_DIST_DIR=

# Fly sets this; local default is 8080 in code
PORT=8080
